# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
APP_NAME="Your Application Name"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com
API_BASE_URL=https://yourdomain.com/api
FRONTEND_URL=https://yourdomain.com
TZ=Africa/Nairobi
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,*.yourdomain.com
SESSION_DOMAIN=.yourdomain.com
SESSION_SAME_SITE=lax
SESSION_SECURE_COOKIE=true
ROUTER_CONFIG_TOKEN_TTL_MINUTES=60

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# SECURITY: Use strong, unique credentials in production
# Generate strong password: openssl rand -base64 32
DB_CONNECTION=pgsql
DB_HOST=wificore-pgbouncer
DB_READ_HOST=wificore-pgbouncer-read
DB_PORT=6432
DB_READ_PORT=6432
DB_DIRECT_HOST=wificore-postgres
DB_DIRECT_PORT=5432
DB_DIRECT_READ_HOST=wificore-postgres-replica
DB_DIRECT_READ_PORT=5432
DB_DATABASE=wms_770_ts
DB_USERNAME=
DB_PASSWORD=
DB_APP_POOL_MODE=transaction
PGBOUNCER_DEFAULT_POOL_SIZE=20
PGBOUNCER_MIN_POOL_SIZE=5
PGBOUNCER_RESERVE_POOL_SIZE=10
PGBOUNCER_MAX_DB_CONNECTIONS=60
PGBOUNCER_MAX_USER_CONNECTIONS=60

# PostgreSQL Replication
POSTGRES_REPLICATION_USER=replicator
POSTGRES_REPLICATION_PASSWORD=
POSTGRES_REPLICATION_SLOT=wificore_replica
POSTGRES_REPLICATION_APPLICATION_NAME=wificore-postgres-replica
POSTGRES_SYNCHRONOUS_COMMIT=on
POSTGRES_SYNCHRONOUS_STANDBY_NAMES=""

# P2 Security: Database Query Timeouts (in milliseconds)
DB_TIMEOUT=5
DB_STATEMENT_TIMEOUT=30000
DB_LOCK_TIMEOUT=10000
DB_PERSISTENT=true

# PostgreSQL Performance Settings
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_MAINTENANCE_WORK_MEM=64MB

# ============================================================================
# DATABASE MIGRATION SETTINGS
# ============================================================================
AUTO_MIGRATE=true
AUTO_SEED=false
FRESH_INSTALL=false

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# SECURITY: Always set a strong Redis password in production
# Generate strong password: openssl rand -base64 32
# IMPORTANT: This file is what Docker Compose reads at runtime for ${REDIS_PASSWORD}
# substitution. If this is blank, ALL containers (scheduler, queues, backend) will
# connect to Redis without a password, causing NOAUTH errors. Set this value here
# AND ensure the Redis container requires auth (requirepass in redis.conf).
REDIS_CLIENT=predis
REDIS_HOST=wificore-redis
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_MAXMEMORY=512mb

# ============================================================================
# MAIL CONFIGURATION
# ============================================================================
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailersend.net
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

MAILERSEND_API_KEY=

# ============================================================================
# BROADCASTING & WEBSOCKETS (SOKETI/PUSHER)
# ============================================================================
BROADCAST_DRIVER=pusher
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=app-id
PUSHER_APP_KEY=app-key
PUSHER_APP_SECRET=app-secret
PUSHER_HOST=wificore-soketi
PUSHER_PORT=6071
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

# Soketi Settings
SOKETI_DEBUG=1
SOKETI_METRICS_ENABLED=1
SOKETI_STATUS_ENDPOINT=http://wificore-soketi:6071/apps/app-id/status

# ============================================================================
# VPN CONFIGURATION
# ============================================================================
VPN_MODE=host
VPN_INTERFACE_NAME=wg0
VPN_SERVER_PUBLIC_IP=
VPN_SERVER_ENDPOINT=vpn.example.com:51830
VPN_LISTEN_PORT=51830
VPN_SERVER_PRIVATE_KEY=
VPN_SERVER_PUBLIC_KEY=
VPN_SUBNET_BASE=10.0.0.0/8

# WireGuard Controller
WIREGUARD_WEBHOOK_API_KEY=
ENABLE_WEBHOOK_MONITOR=true
WEBHOOK_BASE_URL=http://172.70.0.5:9000
WEBHOOK_MONITOR_INTERVAL=5
DOCKER_NETWORK_CIDR=172.70.0.0/16
TELEGRAF_COLLECTOR_IP=172.70.0.20

# ============================================================================
# QUEUE CONFIGURATION
# ============================================================================
QUEUE_CONNECTION=database
QUEUE_MAX_TRIES=3
QUEUE_TIMEOUT=120
QUEUE_RETRY_AFTER=90
QUEUE_BACKOFF=10,30,60

# Queue Workers
QUEUE_WORKERS=10

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================
CACHE_STORE=redis
CACHE_DRIVER=redis
CACHE_PREFIX=app_cache_

# ============================================================================
# SESSION CONFIGURATION
# ============================================================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ============================================================================
# MULTITENANCY CONFIGURATION
# ============================================================================
MULTITENANCY_MODE=schema
AUTO_CREATE_TENANT_SCHEMA=true
AUTO_MIGRATE_TENANT_SCHEMA=true

# ============================================================================
# FREERADIUS CONFIGURATION
# ============================================================================
# SECURITY: Use a strong, unique RADIUS secret
# Generate: openssl rand -base64 24
RADIUS_SERVER_HOST=wificore-freeradius
# RADIUS_SERVER_IP: IP address of FreeRADIUS container in Docker bridge network
# Required for WireGuard PostUp/PostDown iptables rules (hostnames don't resolve in host network mode)
# Default: 172.70.0.2 (FreeRADIUS typically gets this IP in the 172.70.0.0/16 custom bridge)
RADIUS_SERVER_IP=172.70.0.2
RADIUS_SERVER_PORT=1812
RADIUS_SECRET=
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813

# ============================================================================
# MIKROTIK SSH CONFIGURATION
# ============================================================================
MIKROTIK_SSH_PRIVATE_KEY_PATH=/run/secrets/mikrotik_id_rsa
MIKROTIK_SSH_PRIVATE_KEY_PASSPHRASE=
MIKROTIK_SSH_CONNECT_RETRIES=3
MIKROTIK_SSH_CONNECT_RETRY_DELAY=1
MIKROTIK_SSH_AUTO_GENERATE=true
MIKROTIK_SSH_AUTO_BOOTSTRAP=true

# ============================================================================
# M-PESA CONFIGURATION
# ============================================================================
# SECURITY: Use production credentials in production environment
# Obtain from Safaricom Daraja Portal: https://developer.safaricom.co.ke
MPESA_ENV=sandbox
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback
MPESA_INITIATOR_NAME=
MPESA_INITIATOR_PASSWORD=
MPESA_ACCOUNT_REFERENCE=YourCompany
MPESA_TRANSACTION_DESC=Payment
MPESA_ENVIRONMENT=sandbox

# P2 Security: M-Pesa Webhook Signature Verification
MPESA_WEBHOOK_SECRET=
MPESA_PUBLIC_KEY=
MPESA_SKIP_SIGNATURE_VERIFICATION=false

# ============================================================================
# WIREGUARD CONTROLLER CONFIGURATION
# ============================================================================
# SECURITY: Generate a strong API key for WireGuard controller
# Generate: openssl rand -base64 32
# Note: Using custom Docker bridge gateway IP (172.70.255.254) because WireGuard runs in host network mode
# This allows backend container (bridge network) to reach WireGuard controller (host network)
# The gateway IP matches the custom subnet defined in docker-compose: 172.70.0.0/16
WIREGUARD_API_KEY=
WIREGUARD_CONTROLLER_URL=http://172.70.255.254:8080

# ============================================================================
# PROVISIONING SERVICE CONFIGURATION
# ============================================================================
PROVISIONING_SERVICE_API_KEY=
PROVISIONING_DEBUG=false
PROVISIONING_LOG_LEVEL=info

# ============================================================================
# DOCKER IMAGE TAGS
# ============================================================================
NGINX_TAG=latest
FRONTEND_TAG=latest
BACKEND_TAG=latest

# ============================================================================
# EXTERNAL PORTS (Only services that need external access)
# ============================================================================
NGINX_PORT=8070
# RADIUS ports for network devices (APs, routers)
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813

# ============================================================================
# TELEGRAF / METRICS CONFIGURATION
# ============================================================================
ROUTER_POLLING_MODE=telegraf
TELEGRAF_SHARD_INDEX=0
TELEGRAF_SHARD_COUNT=1
TELEGRAF_FAST_INTERVAL=3s
TELEGRAF_SLOW_INTERVAL=30s
TELEGRAF_SNMP_COMMUNITY=traidnet-monitor
VICTORIA_METRICS_WRITE_URL=http://wificore-victoriametrics:8428

# ============================================================================
# DEVELOPMENT/TESTING FLAGS
# ============================================================================
BYPASS_EMAIL_VERIFICATION=false

# ============================================================================
# LOGGING
# ============================================================================
LOG_CHANNEL=stack
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null
LOG_SLACK_WEBHOOK_URL=

# ============================================================================
# SMS CONFIGURATION (Optional)
# ============================================================================
SMS_DRIVER=africastalking
SMS_FROM=WIFICORE
AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_API_KEY=your_api_key

# ============================================================================
# MONITORING & OBSERVABILITY (Optional)
# ============================================================================
# Sentry Error Tracking
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# New Relic APM
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=WifiCore

# ============================================================================
# BACKUP CONFIGURATION (Optional)
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30
BACKUP_DESTINATION=s3

# AWS S3 for Backups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=wificore-backups

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================
# PHP-FPM
PHP_FPM_PM_MAX_CHILDREN=50
PHP_FPM_PM_START_SERVERS=10
PHP_FPM_PM_MIN_SPARE_SERVERS=5
PHP_FPM_PM_MAX_SPARE_SERVERS=20

# ============================================================================
# FEATURE FLAGS (Optional)
# ============================================================================
FEATURE_VPN_ENABLED=true
FEATURE_SMS_ENABLED=true
FEATURE_MPESA_ENABLED=true
FEATURE_RADIUS_ENABLED=true

# ============================================================================
# API RATE LIMITING
# ============================================================================
API_RATE_LIMIT=60
API_RATE_LIMIT_WINDOW=1

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# ============================================================================
# MONGODB / GENIEACS CONFIGURATION
# ============================================================================
MONGO_USERNAME=admin
MONGO_PASSWORD=CHANGE_THIS_MONGO_PASSWORD
GENIEACS_UI_JWT_SECRET=CHANGE_THIS_GENIEACS_SECRET


# ============================================================================
# SAAS BILLING CONFIGURATION
# ============================================================================
SAAS_DEFAULT_PAYBILL=
SAAS_PAYBILL_NAME="WifiCore SaaS"
SAAS_PPPOE_RATE=30.00
SAAS_HOTSPOT_REVENUE_PCT=2.0
SAAS_ROUTER_RATE=100.00
SAAS_BANDWIDTH_RATE=0.50
SAAS_STORAGE_RATE=10.00
SAAS_MINIMUM_SUBSCRIPTION=500.00

# Landlord credentials (change these in production!)
SAAS_LANDLORD_EMAIL=landlord@wificore.local
SAAS_LANDLORD_PASSWORD=Landlord@123!
