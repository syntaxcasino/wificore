FROM php:8.4-cli-bookworm

WORKDIR /var/www/html

# Install only the extensions needed for testing (pdo_pgsql, sockets, zip)
RUN apt-get update -qq && apt-get install -y --no-install-recommends \
    libpq-dev \
    libzip-dev \
    unzip \
    git \
    curl \
 && docker-php-ext-install -j$(nproc) pdo pdo_pgsql sockets zip \
 && rm -rf /var/lib/apt/lists/*

# Install Composer
COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

# Copy source and install ALL deps (including dev for tests)
COPY . .
RUN composer install --no-interaction --no-progress && composer clear-cache

CMD ["php", "artisan", "test", "--no-coverage"]
