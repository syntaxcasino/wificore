FROM php:8.4-fpm-alpine

WORKDIR /var/www/html

# Install runtime + build deps
RUN apk add --no-cache --virtual .build-deps \
    postgresql-dev \
    libzip-dev \
    icu-dev \
    net-snmp-dev \
    linux-headers \
    autoconf \
    g++ \
    make \
 && apk add --no-cache \
    libpq \
    libzip \
    icu-libs \
    net-snmp \
    bash \
    unzip \
    git \
    curl \
 && docker-php-ext-install -j$(nproc) pdo pdo_pgsql sockets zip snmp intl \
 && apk del .build-deps \
 && rm -rf /tmp/* /var/cache/apk/*

# Install Composer
COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

# Copy source and install ALL deps (including dev for tests)
COPY . .
RUN composer install --no-interaction --no-progress && composer clear-cache

CMD ["php", "artisan", "test", "--no-coverage"]
