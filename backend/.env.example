APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Router provisioning token TTL (minutes)
ROUTER_CONFIG_TOKEN_TTL_MINUTES=60

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# DB_EMULATE_PREPARES=true

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
CACHE_PREFIX=traidnet_cache_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=smtp
MAIL_ENCRYPTION=tls
MAIL_PORT=587
MAIL_TIMEOUT=30
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Choose one SMTP provider and uncomment its configuration:

# Brevo (Sendinblue)
MAIL_HOST=smtp-relay.brevo.com
MAIL_USERNAME=your-brevo-username
MAIL_PASSWORD=your-brevo-smtp-key

# SendGrid
#MAIL_HOST=smtp.sendgrid.net
#MAIL_USERNAME=apikey
#MAIL_PASSWORD=your-sendgrid-api-key

# Mailjet
#MAIL_HOST=in-v3.mailjet.com
#MAIL_USERNAME=your-mailjet-api-key
#MAIL_PASSWORD=your-mailjet-secret-key

# SendPulse
#MAIL_HOST=smtp-pulse.com
#MAIL_USERNAME=your-sendpulse-email
#MAIL_PASSWORD=your-sendpulse-password

# MailerSend
#MAIL_HOST=smtp.mailersend.net
#MAIL_USERNAME=MS_xxxxxx@yourdomain.com
#MAIL_PASSWORD=your-mailersend-smtp-password
MAILERSEND_API_KEY=

# SMTP2GO
#MAIL_HOST=mail.smtp2go.com
#MAIL_USERNAME=your-smtp2go-username
#MAIL_PASSWORD=your-smtp2go-password

# Maileroo
#MAIL_HOST=smtp.maileroo.com
#MAIL_USERNAME=your-maileroo-username
#MAIL_PASSWORD=your-maileroo-api-key

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# SAAS BILLING CONFIGURATION
# =============================================================================
SAAS_DEFAULT_PAYBILL=
SAAS_PAYBILL_NAME="WifiCore SaaS"
SAAS_PPPOE_RATE=30.00
SAAS_HOTSPOT_REVENUE_PCT=2.0
SAAS_ROUTER_RATE=100.00
SAAS_BANDWIDTH_RATE=0.50
SAAS_STORAGE_RATE=10.00
SAAS_MINIMUM_SUBSCRIPTION=500.00

# Landlord credentials (change these in production!)
SAAS_LANDLORD_EMAIL=landlord@wificore.local
SAAS_LANDLORD_PASSWORD=Landlord@123!

# =============================================================================
# M-PESA PAYMENT CONFIGURATION
# =============================================================================
# Environment: sandbox or production
MPESA_ENV=sandbox

# API Credentials (get from Safaricom Developer Portal)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=

# Business Shortcode (174379 for sandbox)
MPESA_BUSINESS_SHORTCODE=174379

# IMPORTANT: Callback URL must match your APP_URL domain!
# The callback URL receives payment notifications from M-Pesa.
# If using APP_URL-based default, ensure APP_URL is correct.
# For PPPoE portal, use: https://your-domain.com/api/mpesa/callback
# For hotspot, use: https://your-hotspot-domain.com/api/mpesa/callback
# Default uses: APP_URL + /api/mpesa/callback
# MPESA_CALLBACK_URL=${APP_URL}/api/mpesa/callback

# Account reference shown on user's M-Pesa statement
MPESA_ACCOUNT_REFERENCE=WifiCore

# Transaction description
MPESA_TRANSACTION_DESC=Internet Service Payment

# B2B/B2C Initiator credentials (for refunds/adjustments)
MPESA_INITIATOR_NAME=
MPESA_INITIATOR_PASSWORD=

# API Timeouts (seconds)
MPESA_TIMEOUT=30
MPESA_CONNECT_TIMEOUT=10

# =============================================================================
# PROVISIONING CALLBACK GUARDRAILS (SAFE ROLLOUT)
# =============================================================================
# Stage 1 (observe-only):
# PROVISIONING_REQUIRE_CALLBACK_IDENTITY=false
# PROVISIONING_WARN_MISSING_CALLBACK_IDENTITY=true
# PROVISIONING_REJECT_STALE_CALLBACKS=false
# PROVISIONING_WARN_STALE_CALLBACKS=true
# PROVISIONING_MAX_CALLBACK_SKEW_SECONDS=900
#
# Stage 2 (enforce identity):
# PROVISIONING_REQUIRE_CALLBACK_IDENTITY=true
#
# Stage 3 (enforce stale rejection after time-sync validation):
# PROVISIONING_REJECT_STALE_CALLBACKS=true

PROVISIONING_REQUIRE_CALLBACK_IDENTITY=false
PROVISIONING_WARN_MISSING_CALLBACK_IDENTITY=true
PROVISIONING_MAX_CALLBACK_SKEW_SECONDS=900
PROVISIONING_REJECT_STALE_CALLBACKS=false
PROVISIONING_WARN_STALE_CALLBACKS=true

# Provisioning callback-guard trend alerting
PROVISIONING_CALLBACK_GUARD_ALERT_WINDOW_MINUTES=10
PROVISIONING_CALLBACK_GUARD_ALERT_WARN_DELTA=5
PROVISIONING_CALLBACK_GUARD_ALERT_CRITICAL_DELTA=20
PROVISIONING_CALLBACK_GUARD_ALERT_COOLDOWN_SECONDS=900
